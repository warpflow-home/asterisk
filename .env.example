# Asterisk PBX - Docker Configuration Example
# Copy this file to .env and fill in your own values

# ===== ntfy.sh Notification Settings =====
# URL to send notifications to (e.g., https://ntfy.example.com/mytopic)
NTFY_URL=https://ntfy.example.com/your-topic

# ===== Nextcloud WebDAV Settings =====
# Nextcloud instance URL
NC_URL=https://nextcloud.example.com

# Nextcloud username or email
NC_USER=user@example.com

# Nextcloud app password (generate from Nextcloud Settings > Security)
NC_APP_PASSWORD=abcde-12345-fghij-67890

# ===== Tailscale Configuration =====
# Tailscale auth key for automatic network joining
# Get this from https://login.tailscale.com/admin/authkeys
TS_AUTHKEY=tskey-auth-xxxxx-xxxxx-xxxxx
